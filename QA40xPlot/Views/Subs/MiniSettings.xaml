<Window x:Class="QA40xPlot.Views.MiniSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QA40xPlot.Views"
        mc:Ignorable="d" Background="{Binding BackgroundClr, Mode=OneWay}"
        Title="Edit Settings" Height="220" Width="320">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Margin="5,5,5,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label VerticalAlignment="Center" Content="Amplifier Load: " HorizontalAlignment="Right" Grid.Row="1" Grid.Column="0" 
                  ToolTip="The amplifier load is used to convert power to voltage for all tests."
                   />
            <ComboBox IsEditable="True" Grid.Row="1" Grid.Column="1" MinWidth="80" 
                  Text="{Binding AmplifierLoad}" 
                  ItemsSource="{Binding Impedances}" />
            <Label VerticalAlignment="Center" Content="Ohms" Grid.Row="1" Grid.Column="2" HorizontalAlignment="Left" />

            <Label VerticalAlignment="Center" Content="Balanced I/O:" Grid.Row="3" Grid.Column="0" HorizontalAlignment="Right" />
            <CheckBox  Grid.Row="3" Grid.Column="1" IsChecked="{Binding IsBalancedIO}" 
                       Content="On" VerticalAlignment="Center" />

            <Label VerticalAlignment="Center" Content="Noise Bandwidth: " HorizontalAlignment="Right" Grid.Row="5" Grid.Column="0"
                      ToolTip="Set the noise upper frequency for THD+N and SNR math."
                   />
            <ComboBox IsEditable="True"  Grid.Row="5" Grid.Column="1" MinWidth="80" Text="{Binding NoiseBandwidthStr}" 
                  ItemsSource="{Binding NoiseBandList}" />

            <Label VerticalAlignment="Center" Content="Noise Weighting: " HorizontalAlignment="Right" Grid.Row="7" Grid.Column="0"
                       ToolTip="Noise floor weighting method. Z = none."
                   />
            <ComboBox  Grid.Row="7" Grid.Column="1" MinWidth="80" SelectedValue="{Binding NoiseWeight}" 
                  ItemsSource="{Binding NoiseWeightList}" />

            <Label VerticalAlignment="Center" Content="Test Channel: " HorizontalAlignment="Right" Grid.Row="9" Grid.Column="0"
                       ToolTip="All tests except impedance and gain use this channel as the reference for i/o voltage and power conversions."
                   />
            <ComboBox  Grid.Row="9" Grid.Column="1" MinWidth="80" SelectedValue="{Binding TestChannel}" 
                       ItemsSource="{Binding ChannelList}" />

            <Label VerticalAlignment="Center" Content="Sound Device Channels: " HorizontalAlignment="Right" Grid.Row="11" Grid.Column="0" 
                  ToolTip="Which input channels will be from the external source - for delaying."
                   />
            <ComboBox Grid.Row="11" Grid.Column="1" MinWidth="80" 
                  SelectedItem="{Binding EchoChannel}" 
                  ItemsSource="{Binding EchoChannels}" />


        </Grid>
    </ScrollViewer>
</Window>
